        "projects.title": "Personal Projects",

        "projects.project0.title": "Meridian",
        "projects.project0.date": "2025 -- Present",
        "projects.project0.desc": "Meridian is an open-source platform for creating, visualizing, and interacting with complex graph-based AI workflows. It includes a visual canvas with modular nodes for input, generation, parallelization, and routing, enabling advanced context management and tree-structured conversations. It supports rich content such as Markdown, LaTeX, syntax highlighting for 200+ languages, and AI-generated Mermaid.js diagrams, with deep GitHub integration and cost/token tracking for each model call.",
        "projects.project0.tech": "Nuxt3, Python, FastAPI, PostgreSQL, Neo4j, Docker",

        "projects.project1.title": "gouv.viz",
        "projects.project1.date": "2026 -- Present",
        "projects.project1.desc": "gouv.viz is a static-first web application for visualizing and exploring public votes, deputies, and political groups from the French National Assembly's open data. It uses a local preprocessing pipeline to convert large official JSON exports into an optimized SQLite database, then serves a fast server-rendered interface with Templ and HTMX, styled according to the French State Design System.",
        "projects.project1.tech": "Go, Echo, Templ, HTMX, SQLite, Docker",

        "projects.project2.title": "Letterboxd Statistics",
        "projects.project2.date": "2024",
        "projects.project2.desc": "Letterboxd Statistics is a website that lets users visualize statistics about the most popular films on Letterboxd. It scrapes Letterboxd every 5 minutes to refresh movie statistics and uses an innovative server-rendered charting approach.",
        "projects.project2.tech": "Go, HTMX, Redis, Docker",

        "projects.project3.title": "Letterboxd-Jellyfin Integration",
        "projects.project3.date": "2024",
        "projects.project3.desc": "Letterboxd-Jellyfin Integration is a self-hosted automation tool that continuously synchronizes Letterboxd watchlists with Jellyfin and Radarr. It supports multiple users, incremental scraping, Jellyfin collection management, Radarr download queue integration, proxy-based scraping, and Docker deployment.",
        "projects.project3.tech": "Python, Docker",

        "projects.project4.title": "ugc-alerts",
        "projects.project4.date": "2023",
        "projects.project4.desc": "ugc-alerts is a notification tool that monitors the UGC Cinéma program and alerts users through Discord when a movie is added to the schedule.",
