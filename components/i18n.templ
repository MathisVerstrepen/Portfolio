    "en": {
        "home.subtitle": "Welcome to my portfolio!",
        "home.accent_word": "portfolio",
        "home.text1": "My name is Mathis Verstrepen, I'm a 21 years old French student in Computer Science and Statistics at Polytech in Lille, France.",
        "home.text2": "I've also been a full-stack web developer in my spare time for several years. I love working on websites for personal projects and discovering new technologies!",
        "home.text3": "What do you want to know more about?",
        "home.action_tech&academics": "Tech Stack & Academic career",
