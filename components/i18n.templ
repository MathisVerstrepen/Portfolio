        "tech&academics.title": "Tech Stack & Academic career",
        "tech&academics.description": "This section provides an overview of my academic background, language skills, and preferred technologies.",
        "tech&academics.category1": "Academic career",
        
        "tech&academics.acad.1.name": "Université Laval 🡵",
        "tech&academics.acad.1.place": "Québec, QC, Canada",
        "tech&academics.acad.1.date": "Sep. 2024 -- Present",
        "tech&academics.acad.1.degree": "Master's in Computer Science",
        "tech&academics.acad.1.desc": "Exchange student, double degree in Computer Science.<br><strong>4.08/4.33</strong> 2024 Fall semester GPA - <strong>4.25/4.33</strong> 2025 Winter semester GPA",

        "tech&academics.acad.2.name": "Polytech Lille 🡵",
